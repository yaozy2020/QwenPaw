#!/bin/bash

PYTHON_BIN="/var/apps/python312/target/bin/python3"
CODE_DIR="${TRIM_APPDEST}/qwenpaw/code"
WORKING_DIR="${TRIM_PKGHOME}"
VENV_DIR="${WORKING_DIR}/venv"

export HOME="${WORKING_DIR}"
export QWENPAW_WORKING_DIR="${TRIM_DATA_SHARE_PATHS%%:*}/.qwenpaw"
LOG_FILE="${TRIM_PKGVAR}/qwenpaw-upgrade.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "${LOG_FILE}"
}

log_msg "开始升级 QwenPaw..."

chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGETC}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGVAR}"
chmod -R 755 "${TRIM_PKGETC}"
chmod -R 755 "${TRIM_PKGVAR}"

PID_FILE="${TRIM_PKGVAR}/qwenpaw.pid"
if [ -f "${PID_FILE}" ]; then
    log_msg "正在停止 QwenPaw 进程..."
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if kill -0 "${pid}" 2>/dev/null; then
        kill -TERM "${pid}" 2>/dev/null || true
        count=0
        while kill -0 "${pid}" 2>/dev/null && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        kill -KILL "${pid}" 2>/dev/null || true
    fi
    rm -f "${PID_FILE}"
fi

rm -rf "${VENV_DIR}"
"${PYTHON_BIN}" -m venv "${VENV_DIR}"
chmod -R 755 "${VENV_DIR}"

log_msg "正在激活虚拟环境..."
source "${VENV_DIR}/bin/activate"
log_msg "虚拟环境激活成功"

PYPI_MIRROR="${wizard_pypi_mirror:-tsinghua}"
PIP_OPTS=""

if [ "$PYPI_MIRROR" = "tsinghua" ]; then
    PIP_OPTS="-i https://pypi.tuna.tsinghua.edu.cn/simple"
elif [ "$PYPI_MIRROR" = "aliyun" ]; then
    PIP_OPTS="-i https://mirrors.aliyun.com/pypi/simple/"
elif [ "$PYPI_MIRROR" = "ustc" ]; then
    PIP_OPTS="-i https://pypi.mirrors.ustc.edu.cn/simple/"
fi

cd "${CODE_DIR}" || exit 1

log_msg "正在安装 QwenPaw (源码模式)..."
PIP_LOG=$(mktemp)
if ! pip3 install -e . $PIP_OPTS > "${PIP_LOG}" 2>&1; then
    cat "${PIP_LOG}" >> "${LOG_FILE}"
    rm -f "${PIP_LOG}"
    log_msg "QwenPaw 升级失败！"
    exit 1
fi
cat "${PIP_LOG}" >> "${LOG_FILE}"
rm -f "${PIP_LOG}"

chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${WORKING_DIR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGVAR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGETC}"
chmod -R 755 "${WORKING_DIR}"
chmod -R 755 "${TRIM_PKGVAR}"
chmod -R 755 "${TRIM_PKGETC}"

# 调用 install_init / upgrade_init 做环境检查（如果存在）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -f "${SCRIPT_DIR}/install_init" ]; then
    log_msg "running install_init ..."
    bash "${SCRIPT_DIR}/install_init" 2>&1 | while read -r line; do log_msg "install_init: ${line}"; done || true
fi

if [ -f "${SCRIPT_DIR}/upgrade_init" ]; then
    log_msg "running upgrade_init ..."
    bash "${SCRIPT_DIR}/upgrade_init" 2>&1 | while read -r line; do log_msg "upgrade_init: ${line}"; done || true
fi

# v1.1.12.5: 升级完成后自动重启主服务（修复升级后需手动启停的体验问题）
if [ -f "${SCRIPT_DIR}/main" ]; then
    log_msg "正在重启 QwenPaw 主服务..."
    # 停旧进程（main stop 会自动检查 PID_FILE）
    bash "${SCRIPT_DIR}/main" stop 2>&1 | while read -r line; do log_msg "main stop: ${line}"; done || true
    # 启新进程
    bash "${SCRIPT_DIR}/main" start 2>&1 | while read -r line; do log_msg "main start: ${line}"; done || true
    sleep 2
    if bash "${SCRIPT_DIR}/main" status >/dev/null 2>&1; then
        log_msg "主服务重启成功"
    else
        log_msg "WARNING: 主服务重启失败，请手动运行 main start 或重启应用"
    fi
fi

log_msg "QwenPaw 升级成功！"
exit 0
