{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "permissions": [
    "backend",
    "backend-download",
    "core:default",
    "dialog:allow-save",
    "open-external-link"
  ]
}
